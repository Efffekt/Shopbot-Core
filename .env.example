# ===========================================
# Shopbot-Core Environment Variables
# Copy this file to .env.local and fill in values
# ===========================================

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJ...  # anon/public key
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # service role key (server-side only, never expose)

# --- Google Vertex AI / Gemini (required for chat) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}  # full JSON key

# --- OpenAI (required for embeddings + fallback LLM) ---
OPENAI_API_KEY=sk-...

# --- Admin Access (required) ---
NEXT_PUBLIC_SUPER_ADMIN_EMAILS=admin@example.com,admin2@example.com  # full admin panel access
NEXT_PUBLIC_ADMIN_EMAILS=editor@example.com  # limited access (overview, analytics, blog)

# --- Upstash Redis (optional — rate limiting degrades gracefully without it) ---
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# --- Firecrawl (optional — web scraping disabled without it) ---
FIRECRAWL_API_KEY=fc-...

# --- Resend (optional — email notifications disabled without it) ---
RESEND_API_KEY=re_...  # from resend.com dashboard
RESEND_FROM_EMAIL=noreply@preik.ai  # verified sender address (default: noreply@preik.ai)

# --- Vercel Cron (optional — needed for scheduled credit resets) ---
CRON_SECRET=your-cron-secret-here  # Vercel auto-injects for cron requests

# --- Contact Form CORS (optional — defaults to preik.no origins) ---
CONTACT_ALLOWED_ORIGINS=https://preik.no,https://www.preik.no  # comma-separated

# --- Stripe (required for self-service tenant provisioning) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...  # publishable key (safe for browser)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...  # Stripe Price ID for Starter plan (299 kr/mnd)
STRIPE_PRO_PRICE_ID=price_...      # Stripe Price ID for Pro plan (799 kr/mnd)

# --- Facebook Conversions API (optional — server-side event tracking) ---
FB_CONVERSIONS_API_TOKEN=EAAG...  # from Events Manager → Settings → Generate access token
FB_TEST_EVENT_CODE=              # temporary test code from Events Manager (remove after verification)

# --- Sentry (optional — error tracking disabled without it) ---
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# --- Logging (optional) ---
LOG_LEVEL=info  # debug | info | warn | error (default: info in prod, debug in dev)
